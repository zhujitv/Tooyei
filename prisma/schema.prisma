generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Locale {
  ZH
  EN
  ES
  DE
  JA
  FR
  RU
  IT
  PT
  NL
  PL
  TR
  AR
  RO
  CS
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum TranslationStatus {
  MISSING
  MACHINE_DRAFT
  NEEDS_REVIEW
  PUBLISHED
}

enum TranslationJobStatus {
  PENDING
  RUNNING
  PAUSED
  COMPLETED
  PARTIAL_FAILED
  FAILED
  CANCELLED
  CLOSED
}

enum TranslationJobItemStatus {
  PENDING
  RUNNING
  TRANSLATED
  QA_PASSED
  QA_WARNING
  QA_FAILED
  NEEDS_REVIEW
  COMPLETED
  FAILED
  SKIPPED
  CANCELLED
}

enum ProductKind {
  SPC
  ESPC
  VSPC
  LSPC
  WPC
  LVT
  LAMINATE
  WALL_PANEL
  ACCESSORY
}

enum MediaKind {
  IMAGE
  VIDEO
  DOCUMENT
}

enum AssetType {
  IMAGE
  VIDEO
  DOCUMENT
  CERTIFICATE
  CATALOG
  SPEC_SHEET
  INSTALLATION_GUIDE
  WARRANTY
  OTHER
}

enum StorageProvider {
  VERCEL_BLOB
  EXTERNAL
  LOCAL
}

enum ProductMediaRole {
  PRIMARY
  GALLERY
  DETAIL
  APPLICATION
  PACKAGING
  VIDEO
}

enum ProductDownloadKind {
  CATALOG
  SPEC_SHEET
  INSTALLATION_GUIDE
  WARRANTY
  CERTIFICATE
  OTHER
}

enum ArticleKind {
  NEWS
  GUIDE
  CASE_STUDY
}

enum InquiryStatus {
  NEW
  QUALIFIED
  IN_PROGRESS
  WON
  LOST
  SPAM
}

enum InquiryNoteKind {
  GENERAL
  CALL
  EMAIL
  WHATSAPP
  QUOTE
  SAMPLE
  MEETING
  OTHER
}

enum AdminRole {
  OWNER
  EDITOR
  TRANSLATOR
  SALES
  VIEWER
}

model Category {
  id                 String                @id @default(cuid())
  slug               String                @unique
  kind               ProductKind
  status             ContentStatus         @default(DRAFT)
  isActive           Boolean               @default(true)
  coverImage         String?
  coverAssetId       String?
  coverAsset         MediaAsset?           @relation("CategoryCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  sortOrder          Int                   @default(0)
  parentId           String?
  parent             Category?             @relation("CategoryTree", fields: [parentId], references: [id], onDelete: SetNull)
  children           Category[]            @relation("CategoryTree")
  translations       CategoryTranslation[]
  products           Product[]
  productAssignments ProductCategory[]
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt

  @@index([isActive, sortOrder])
  @@index([status, sortOrder])
  @@index([parentId])
  @@index([coverAssetId])
}

model CategoryTranslation {
  id             String            @id @default(cuid())
  categoryId     String
  category       Category          @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  locale         Locale
  status         TranslationStatus @default(MISSING)
  name           String
  description    String?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([categoryId, locale])
  @@index([locale, status])
}

model Product {
  id                  String                      @id @default(cuid())
  slug                String                      @unique
  sku                 String                      @unique
  kind                ProductKind
  status              ContentStatus               @default(DRAFT)
  featured            Boolean                     @default(false)
  sortOrder           Int                         @default(0)
  categoryId          String
  category            Category                    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  categoryAssignments ProductCategory[]
  primaryImageId      String?
  primaryImage        MediaAsset?                 @relation("ProductPrimaryImage", fields: [primaryImageId], references: [id], onDelete: SetNull)
  translations        ProductTranslation[]
  features            ProductFeature[]
  specifications      ProductSpecification[]
  media               ProductMedia[]
  applications        ProductApplication[]
  downloads           ProductDownload[]
  inquiries           InquiryProduct[]
  translationJobItems ProductTranslationJobItem[]
  createdAt           DateTime                    @default(now())
  updatedAt           DateTime                    @updatedAt

  @@index([status, featured, sortOrder])
  @@index([categoryId])
}

model ProductCategory {
  productId  String
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())

  @@id([productId, categoryId])
  @@index([categoryId, sortOrder])
  @@index([productId, sortOrder])
}

model ProductTranslation {
  id             String            @id @default(cuid())
  productId      String
  product        Product           @relation(fields: [productId], references: [id], onDelete: Cascade)
  locale         Locale
  status         TranslationStatus @default(MISSING)
  title          String
  summary        String
  content        Json?
  seoTitle       String?
  seoDescription String?
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([productId, locale])
  @@index([locale, status])
}

model ProductTranslationJob {
  id               String                      @id @default(cuid())
  status           TranslationJobStatus        @default(PENDING)
  sourceLocale     Locale
  targetLocales    Locale[]
  provider         String                      @default("openai-responses")
  model            String
  totalItems       Int                         @default(0)
  completedItems   Int                         @default(0)
  failedItems      Int                         @default(0)
  skippedItems     Int                         @default(0)
  cancelledItems   Int                         @default(0)
  qaPassedItems    Int                         @default(0)
  qaWarningItems   Int                         @default(0)
  qaFailedItems    Int                         @default(0)
  needsReviewItems Int                         @default(0)
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  lastError        String?
  executionId      String?                     @unique
  lockedAt         DateTime?
  lockedBy         String?
  heartbeatAt      DateTime?
  contentTypes     String[]                    @default(["PRODUCT", "MEDIA_ALT", "MEDIA_CAPTION", "FEATURE_TITLE", "FEATURE_DESCRIPTION", "SPEC_LABEL", "SPEC_VALUE", "APPLICATION_TITLE", "APPLICATION_DESCRIPTION", "DOWNLOAD_TITLE", "SEO"])
  requestedById    String?
  requestedBy      AdminUser?                  @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  items            ProductTranslationJobItem[]
  logs             ProductTranslationLog[]
  createdAt        DateTime                    @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  cancelledAt      DateTime?
  closedAt         DateTime?
  updatedAt        DateTime                    @updatedAt

  @@index([status, createdAt])
  @@index([status, heartbeatAt])
  @@index([requestedById, createdAt])
}

model ProductTranslationJobItem {
  id                     String                   @id @default(cuid())
  jobId                  String
  job                    ProductTranslationJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  productId              String
  product                Product                  @relation(fields: [productId], references: [id], onDelete: Restrict)
  productSlug            String
  productSku             String
  sourceLocale           Locale
  targetLocale           Locale
  status                 TranslationJobItemStatus @default(PENDING)
  inputHash              String?
  responseId             String?
  output                 Json?
  warnings               Json?
  errorType              String?
  errorMessage           String?
  rawResponse            String?                  @db.Text
  promptTokens           Int?
  completionTokens       Int?
  totalTokens            Int?
  attemptCount           Int                      @default(0)
  retryCount             Int                      @default(0)
  currentRunAttemptCount Int                      @default(0)
  qaStatus               String?
  qaIssues               Json?
  qaErrorCount           Int                      @default(0)
  qaWarningCount         Int                      @default(0)
  qaAttemptCount         Int                      @default(0)
  qaVersion              String?
  lastQaAt               DateTime?
  savedAt                DateTime?
  durationMs             Int?
  contentTypes           String[]                 @default(["PRODUCT", "MEDIA_ALT", "MEDIA_CAPTION", "FEATURE_TITLE", "FEATURE_DESCRIPTION", "SPEC_LABEL", "SPEC_VALUE", "APPLICATION_TITLE", "APPLICATION_DESCRIPTION", "DOWNLOAD_TITLE", "SEO"])
  processingStep         String                   @default("QUEUED")
  heartbeatAt            DateTime?
  nextAttemptAt          DateTime?
  workerId               String?
  logs                   ProductTranslationLog[]
  createdAt              DateTime                 @default(now())
  startedAt              DateTime?
  completedAt            DateTime?
  updatedAt              DateTime                 @updatedAt

  @@unique([jobId, productId, targetLocale])
  @@index([jobId, status, createdAt])
  @@index([status, nextAttemptAt, createdAt])
  @@index([productId, targetLocale, createdAt])
}

model ProductTranslationLog {
  id                String                    @id @default(cuid())
  jobId             String
  job               ProductTranslationJob     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  itemId            String
  item              ProductTranslationJobItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  provider          String
  model             String
  targetLocale      Locale
  promptVersion     String
  attemptNumber     Int
  errorType         String?
  errorMessage      String?                   @db.Text
  rawResponse       String?                   @db.Text
  requestStartedAt  DateTime
  requestFinishedAt DateTime
  durationMs        Int
  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  qaCodes           String[]                  @default([])
  qaStatus          String?
  createdAt         DateTime                  @default(now())

  @@index([jobId, createdAt])
  @@index([itemId, createdAt])
}

model ProductFeature {
  id           String                      @id @default(cuid())
  productId    String
  product      Product                     @relation(fields: [productId], references: [id], onDelete: Cascade)
  icon         String?
  visible      Boolean                     @default(true)
  sortOrder    Int                         @default(0)
  translations ProductFeatureTranslation[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@index([productId, sortOrder])
  @@index([productId, visible, sortOrder])
}

model ProductFeatureTranslation {
  id          String         @id @default(cuid())
  featureId   String
  feature     ProductFeature @relation(fields: [featureId], references: [id], onDelete: Cascade)
  locale      Locale
  value       String
  description String?

  @@unique([featureId, locale])
}

model ProductSpecification {
  id           String                            @id @default(cuid())
  productId    String
  product      Product                           @relation(fields: [productId], references: [id], onDelete: Cascade)
  group        String?
  value        String
  unit         String?
  visible      Boolean                           @default(true)
  sortOrder    Int                               @default(0)
  translations ProductSpecificationTranslation[]
  createdAt    DateTime                          @default(now())
  updatedAt    DateTime                          @updatedAt

  @@index([productId, sortOrder])
  @@index([productId, visible, sortOrder])
}

model ProductSpecificationTranslation {
  id              String               @id @default(cuid())
  specificationId String
  specification   ProductSpecification @relation(fields: [specificationId], references: [id], onDelete: Cascade)
  locale          Locale
  group           String?
  label           String
  displayValue    String?

  @@unique([specificationId, locale])
}

model MediaAsset {
  id               String               @id @default(cuid())
  kind             MediaKind            @default(IMAGE)
  assetType        AssetType            @default(OTHER)
  pathname         String               @unique
  url              String
  originalFilename String?
  alt              String?
  mimeType         String
  width            Int?
  height           Int?
  sizeBytes        Int?
  checksum         String?
  storageProvider  StorageProvider      @default(EXTERNAL)
  uploadedAt       DateTime?
  orphanedAt       DateTime?
  deletedAt        DateTime?
  blobDeletedAt    DateTime?
  uploadedById     String?
  uploadedBy       AdminUser?           @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  products         ProductMedia[]
  primaryFor       Product[]            @relation("ProductPrimaryImage")
  applications     ProductApplication[] @relation("ProductApplicationImage")
  downloads        ProductDownload[]    @relation("ProductDownloadAsset")
  categoryCovers   Category[]           @relation("CategoryCoverAsset")
  articleCovers    Article[]            @relation("ArticleCoverAsset")
  articleMedia     ArticleMedia[]
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  @@index([assetType, createdAt])
  @@index([storageProvider, orphanedAt, deletedAt])
  @@index([uploadedById, createdAt])
}

model ProductMedia {
  productId    String
  product      Product                   @relation(fields: [productId], references: [id], onDelete: Cascade)
  assetId      String
  asset        MediaAsset                @relation(fields: [assetId], references: [id], onDelete: Cascade)
  role         ProductMediaRole          @default(GALLERY)
  alt          String?
  caption      String?
  translations ProductMediaTranslation[]
  visible      Boolean                   @default(true)
  sortOrder    Int                       @default(0)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt

  @@id([productId, assetId])
  @@index([productId, sortOrder])
  @@index([productId, role, visible, sortOrder])
}

model ProductMediaTranslation {
  id        String       @id @default(cuid())
  productId String
  assetId   String
  media     ProductMedia @relation(fields: [productId, assetId], references: [productId, assetId], onDelete: Cascade)
  locale    Locale
  alt       String
  caption   String?

  @@unique([productId, assetId, locale])
  @@index([locale])
}

model ProductApplication {
  id           String                          @id @default(cuid())
  productId    String
  product      Product                         @relation(fields: [productId], references: [id], onDelete: Cascade)
  imageAssetId String?
  imageAsset   MediaAsset?                     @relation("ProductApplicationImage", fields: [imageAssetId], references: [id], onDelete: SetNull)
  visible      Boolean                         @default(true)
  sortOrder    Int                             @default(0)
  translations ProductApplicationTranslation[]
  createdAt    DateTime                        @default(now())
  updatedAt    DateTime                        @updatedAt

  @@index([productId, visible, sortOrder])
}

model ProductApplicationTranslation {
  id            String             @id @default(cuid())
  applicationId String
  application   ProductApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  locale        Locale
  title         String
  description   String?
  imageAlt      String?

  @@unique([applicationId, locale])
}

model ProductDownload {
  id           String                       @id @default(cuid())
  productId    String
  product      Product                      @relation(fields: [productId], references: [id], onDelete: Cascade)
  assetId      String
  asset        MediaAsset                   @relation("ProductDownloadAsset", fields: [assetId], references: [id], onDelete: Cascade)
  kind         ProductDownloadKind          @default(OTHER)
  visible      Boolean                      @default(true)
  sortOrder    Int                          @default(0)
  translations ProductDownloadTranslation[]
  createdAt    DateTime                     @default(now())
  updatedAt    DateTime                     @updatedAt

  @@index([productId, visible, sortOrder])
  @@index([assetId])
}

model ProductDownloadTranslation {
  id          String          @id @default(cuid())
  downloadId  String
  download    ProductDownload @relation(fields: [downloadId], references: [id], onDelete: Cascade)
  locale      Locale
  title       String
  description String?

  @@unique([downloadId, locale])
}

model Article {
  id              String                  @id @default(cuid())
  slug            String                  @unique
  kind            ArticleKind             @default(NEWS)
  status          ContentStatus           @default(DRAFT)
  featured        Boolean                 @default(false)
  coverImage      String?
  coverAssetId    String?
  coverAsset      MediaAsset?             @relation("ArticleCoverAsset", fields: [coverAssetId], references: [id], onDelete: SetNull)
  authorName      String?
  publishedAt     DateTime?
  translations    ArticleTranslation[]
  translationJobs ArticleTranslationJob[]
  media           ArticleMedia[]
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([status, publishedAt])
  @@index([status, featured, publishedAt])
  @@index([coverAssetId])
}

model ArticleMedia {
  articleId String
  article   Article    @relation(fields: [articleId], references: [id], onDelete: Cascade)
  assetId   String
  asset     MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@id([articleId, assetId])
  @@index([assetId])
}

model ArticleTranslation {
  id             String            @id @default(cuid())
  articleId      String
  article        Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale         Locale
  status         TranslationStatus @default(MISSING)
  title          String
  excerpt        String?
  content        Json
  seoTitle       String?
  seoDescription String?
  readingMinutes Int               @default(1)
  publishedAt    DateTime?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([articleId, locale])
  @@index([locale, status])
}

model ArticleTranslationJob {
  id               String                      @id @default(cuid())
  articleId        String
  article          Article                     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  status           TranslationJobStatus        @default(PENDING)
  sourceLocale     Locale                      @default(EN)
  targetLocales    Locale[]
  provider         String
  model            String
  totalItems       Int                         @default(0)
  completedItems   Int                         @default(0)
  failedItems      Int                         @default(0)
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  lastError        String?
  executionId      String?                     @unique
  lockedAt         DateTime?
  lockedBy         String?
  heartbeatAt      DateTime?
  requestedById    String?
  requestedBy      AdminUser?                  @relation(fields: [requestedById], references: [id], onDelete: SetNull)
  items            ArticleTranslationJobItem[]
  createdAt        DateTime                    @default(now())
  startedAt        DateTime?
  completedAt      DateTime?
  updatedAt        DateTime                    @updatedAt

  @@index([status, createdAt])
  @@index([status, heartbeatAt])
  @@index([articleId, createdAt])
  @@index([requestedById, createdAt])
}

model ArticleTranslationJobItem {
  id               String                   @id @default(cuid())
  jobId            String
  job              ArticleTranslationJob    @relation(fields: [jobId], references: [id], onDelete: Cascade)
  targetLocale     Locale
  status           TranslationJobItemStatus @default(PENDING)
  inputHash        String?
  responseId       String?
  output           Json?
  warnings         Json?
  errorType        String?
  errorMessage     String?                  @db.Text
  rawResponse      String?                  @db.Text
  promptTokens     Int?
  completionTokens Int?
  totalTokens      Int?
  attemptCount     Int                      @default(0)
  nextAttemptAt    DateTime?
  workerId         String?
  heartbeatAt      DateTime?
  startedAt        DateTime?
  completedAt      DateTime?
  createdAt        DateTime                 @default(now())
  updatedAt        DateTime                 @updatedAt

  @@unique([jobId, targetLocale])
  @@index([jobId, status, createdAt])
  @@index([status, nextAttemptAt, createdAt])
}

model Faq {
  id           String           @id @default(cuid())
  status       ContentStatus    @default(DRAFT)
  sortOrder    Int              @default(0)
  translations FaqTranslation[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, sortOrder])
}

model FaqTranslation {
  id          String            @id @default(cuid())
  faqId       String
  faq         Faq               @relation(fields: [faqId], references: [id], onDelete: Cascade)
  locale      Locale
  status      TranslationStatus @default(MISSING)
  question    String
  answer      String
  publishedAt DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@unique([faqId, locale])
  @@index([locale, status])
}

model Inquiry {
  id           String           @id @default(cuid())
  status       InquiryStatus    @default(NEW)
  name         String
  email        String
  phone        String?
  company      String?
  country      String?
  message      String
  locale       Locale           @default(EN)
  sourcePath   String?
  utmSource    String?
  utmMedium    String?
  utmCampaign  String?
  assignedToId String?
  assignedTo   AdminUser?       @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  products     InquiryProduct[]
  notes        InquiryNote[]
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([status, createdAt])
  @@index([email])
  @@index([assignedToId])
}

model InquiryProduct {
  inquiryId String
  inquiry   Inquiry @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@id([inquiryId, productId])
}

model InquiryNote {
  id             String          @id @default(cuid())
  inquiryId      String
  inquiry        Inquiry         @relation(fields: [inquiryId], references: [id], onDelete: Cascade)
  authorId       String?
  author         AdminUser?      @relation(fields: [authorId], references: [id], onDelete: SetNull)
  kind           InquiryNoteKind @default(GENERAL)
  body           String
  nextFollowUpAt DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([inquiryId, createdAt])
  @@index([authorId, createdAt])
  @@index([nextFollowUpAt])
}

model Redirect {
  id          String   @id @default(cuid())
  source      String   @unique
  destination String
  permanent   Boolean  @default(true)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([active])
}

model SocialLink {
  id        String   @id @default(cuid())
  platform  String
  label     String
  url       String
  icon      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
  @@index([platform])
}

model SiteSetting {
  id                    String   @id @default("site")
  siteName              String
  legalName             String
  description           String
  siteUrl               String
  defaultSeoTitle       String
  defaultSeoDescription String
  email                 String
  phone                 String
  whatsappDisplay       String
  address               String?
  inquiryEmail          String?
  notificationEmail     String?
  timezone              String   @default("Asia/Shanghai")
  defaultLocale         String   @default("zh")
  allowIndexing         Boolean  @default(true)
  maintenanceMode       Boolean  @default(false)
  updatedAt             DateTime @updatedAt
  createdAt             DateTime @default(now())
}

model RateLimitCounter {
  id        String   @id @default(cuid())
  key       String   @unique
  count     Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([expiresAt])
}

model AdminUser {
  id                     String                  @id @default(cuid())
  email                  String                  @unique
  name                   String
  passwordHash           String
  role                   AdminRole               @default(EDITOR)
  active                 Boolean                 @default(true)
  inquiries              Inquiry[]
  inquiryNotes           InquiryNote[]
  sessions               AdminSession[]
  auditLogs              AuditLog[]
  translationJobs        ProductTranslationJob[]
  articleTranslationJobs ArticleTranslationJob[]
  uploadedAssets         MediaAsset[]
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
}

model AdminSession {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  userId    String
  user      AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id         String     @id @default(cuid())
  actorId    String?
  actor      AdminUser? @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  metadata   Json?
  createdAt  DateTime   @default(now())

  @@index([actorId, createdAt])
  @@index([entityType, entityId])
}
