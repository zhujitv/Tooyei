{
  "name": "tooyei",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "postinstall": "prisma generate",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "npm run test:translation && npm run test:media && npm run test:product",
    "test:translation": "node --import tsx --test src/lib/translation-response-parser.test.ts src/lib/translation-job-state.test.ts src/lib/translation-execution-status.test.ts src/lib/translation-glossary.test.ts src/lib/translation/quality.test.ts src/lib/product-locale-completeness.test.ts src/lib/translation-providers/doubao-translation-document.test.ts",
    "test:media": "node --import tsx --test src/lib/media-asset-policy.test.ts",
    "test:product": "node --import tsx --test src/lib/product-publication.test.ts",
    "db:generate": "prisma generate",
    "db:validate": "prisma validate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "node scripts/deploy-migrations.mjs",
    "db:deploy:prisma": "prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "catalog:export": "tsx scripts/import-legacy-products.ts --export-only",
    "catalog:import": "tsx scripts/import-legacy-products.ts",
    "verify:production": "tsx scripts/verify-production.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vercel/blob": "^2.0.1",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.24.0",
    "next": "16.2.10",
    "openai": "^6.48.0",
    "pg": "^8.22.0",
    "radix-ui": "^1.6.2",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "shadcn": "^4.13.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.10",
    "prisma": "^7.8.0",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "8.5.19",
    "@prisma/dev": {
      "@hono/node-server": "1.19.14"
    }
  }
}
