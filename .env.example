# PostgreSQL connection used by Prisma Client at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tooyei?sslmode=require"

# Temporary first-party admin authentication. Replace all values in production.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="\$2b\$12\$REPLACE_WITH_A_BCRYPT_HASH"
ADMIN_SESSION_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES"

# Public canonical origin.
NEXT_PUBLIC_SITE_URL="https://www.tooyei.com"

# Optional Resend notification for new public inquiries.
# Leave empty in local development to save inquiries without sending email.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Tooyei <onboarding@resend.dev>"
INQUIRY_NOTIFICATION_EMAIL="sales@example.com"

# Public inquiry rate limits. Defaults are used when these are omitted.
INQUIRY_IP_LIMIT_PER_HOUR="8"
INQUIRY_EMAIL_LIMIT_PER_HOUR="3"
