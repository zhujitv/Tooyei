# PostgreSQL connection used by Prisma Client at runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/tooyei?sslmode=require"

# Temporary first-party admin authentication. Replace all values in production.
# With DATABASE_URL configured, these values bootstrap the first owner account;
# ongoing password changes should be made from /admin/users.
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD_HASH="\$2b\$12\$REPLACE_WITH_A_BCRYPT_HASH"
ADMIN_SESSION_SECRET="REPLACE_WITH_AT_LEAST_32_RANDOM_BYTES"

# Public canonical origin.
NEXT_PUBLIC_SITE_URL="https://www.tooyei.com"

# Optional Resend notification for new public inquiries.
# Leave empty in local development to save inquiries without sending email.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Tooyei <onboarding@resend.dev>"
INQUIRY_NOTIFICATION_EMAIL="sales@example.com"

# Public inquiry rate limits. Defaults are used when these are omitted.
INQUIRY_IP_LIMIT_PER_HOUR="8"
INQUIRY_EMAIL_LIMIT_PER_HOUR="3"

# Vercel Blob token. Automatically injected after linking a Blob store.
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_REPLACE_ME"

# Optional modular AI-assisted product localization. Generated copy is always
# saved as MACHINE_DRAFT and must be reviewed before publishing.
# Default adapter selected when the admin creates a new job.
# Supported: openai-responses | openai-compatible | volcengine-doubao
TRANSLATION_PROVIDER="openai-responses"
TRANSLATION_API_KEY=""
TRANSLATION_API_BASE_URL="https://api.openai.com/v1"
TRANSLATION_MODEL="gpt-5.6-sol"
TRANSLATION_RESPONSE_FORMAT="json_schema"
TRANSLATION_REQUEST_TIMEOUT_MS="110000"

# Legacy OpenAI names remain accepted by the openai-responses adapter.
OPENAI_API_KEY=""
OPENAI_TRANSLATION_MODEL="gpt-5.6-sol"

# Volcengine Ark / Doubao through the official OpenAI Node SDK compatibility
# mode. DOUBAO_MODEL can be a supported model ID or your inference endpoint ID.
DOUBAO_API_KEY=""
DOUBAO_API_BASE_URL="https://ark.cn-beijing.volces.com/api/v3"
DOUBAO_MODEL="doubao-seed-2-0-lite-260215"
DOUBAO_RESPONSE_FORMAT="json_object"
DOUBAO_REQUEST_TIMEOUT_MS="110000"

# Optional origin override used only by `npm run verify:production`.
PRODUCTION_VERIFY_ORIGIN="https://tooyei.vercel.app"
